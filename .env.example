# App
EXPO_PUBLIC_APP_NAME=Codex Sleep
EXPO_PUBLIC_APP_ENV=development

# Audio Content
EXPO_PUBLIC_AUDIO_SOURCE=local
EXPO_PUBLIC_ENABLE_MUSIC_SLEEP=true
EXPO_PUBLIC_ENABLE_STORY_SLEEP=true
EXPO_PUBLIC_ENABLE_NOISE_SLEEP=true

# Feature Flags
EXPO_PUBLIC_ENABLE_SLEEP_TIMER=true
EXPO_PUBLIC_ENABLE_FAVORITES=true
EXPO_PUBLIC_ENABLE_SLEEP_LOG=true
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=false

# Future Remote Content, unused in local MVP
EXPO_PUBLIC_AUDIO_CDN_BASE_URL=

# Alibaba Cloud Account Sync
# Deploy the Function Compute HTTP API, then use its public HTTPS endpoint.
EXPO_PUBLIC_API_BASE_URL=
