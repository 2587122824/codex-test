# Required RDS PostgreSQL connection
DB_HOST=your-rds-host.pg.rds.aliyuncs.com
DB_PORT=5432
DB_NAME=codex_sleep
DB_USER=codex_sleep_app
DB_PASSWORD=replace-with-rds-password

# Required Alibaba Cloud SMS
ALIYUN_ACCESS_KEY_ID=replace-with-access-key-id
ALIYUN_ACCESS_KEY_SECRET=replace-with-access-key-secret
ALIYUN_SMS_SIGN_NAME=replace-with-sms-sign-name
ALIYUN_SMS_TEMPLATE_CODE=replace-with-sms-template-code
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com

# Required session signing secret
SESSION_SECRET=replace-with-long-random-secret

# Optional beta limits
SMS_CODE_TTL_SECONDS=300
SESSION_TTL_SECONDS=604800
SMS_SEND_COOLDOWN_SECONDS=60
SMS_SEND_HOURLY_LIMIT=5
